# ─── Google Ads API (v23 REST) ──────────────────────────────────────
# OAuth credentials — get these from https://console.cloud.google.com/apis/credentials
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=

# Developer token — get from Google Ads UI → Tools → API Center
# (needs Basic or Explorer access for production)
GOOGLE_ADS_DEVELOPER_TOKEN=

# Target customer ID (no dashes, e.g. 2724892809)
GOOGLE_ADS_CUSTOMER_ID=

# Optional: set only if you're accessing through a manager account.
# Leave blank when the OAuth user has direct access to the customer.
# GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# ─── Gemini (creative generation) ───────────────────────────────────
# Get from https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=

# ─── MCP server only (optional) ─────────────────────────────────────
# Where the deployed AlgoAds app lives
ALGOADS_BASE_URL=https://algoads.vercel.app
# Bypass token if you enabled Vercel deployment protection
# ALGOADS_API_TOKEN=
